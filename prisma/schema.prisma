// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Categorias de Produtos ──────────────────────────────────────────────────
model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  namePt      String
  nameEn      String
  nameFr      String?
  nameDe      String?
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  products Product[]
}

// ─── Produtos do Catálogo ────────────────────────────────────────────────────
model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  namePt          String
  nameEn          String?
  nameFr          String?
  nameDe          String?
  descriptionPt   String?
  descriptionEn   String?
  descriptionFr   String?
  descriptionDe   String?
  price           Float    @default(0)
  compareAtPrice  Float?   // Preço riscado (desconto)
  currency        String   @default("EUR")
  stockQuantity   Int      @default(0)
  categoryId      String?
  imageUrl        String?
  images          String?  // JSON array of image URLs
  weight          Float?   // Peso em kg
  origin          String?  // Ilha de origem
  featured        Boolean  @default(false)
  tags            String?  // JSON array of tags
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

// ─── Perfis de Utilizador ────────────────────────────────────────────────────
model Profile {
  id         String   @id @default(cuid())
  fullName   String?
  vatNumber  String?
  address    String?
  city       String?
  postalCode String?
  country    String?
  phone      String?
  isAdmin    Boolean  @default(false)
  email      String   @unique
  updatedAt  DateTime @updatedAt

  orders Order[]
}

// ─── Encomendas ──────────────────────────────────────────────────────────────
model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  profileId         String?
  status            String   @default("pendente")
  // Dados do cliente
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  customerVat       String?
  // Endereço de entrega
  shippingAddress   String?
  shippingCity      String?
  shippingPostalCode String?
  shippingCountry   String?
  // Valores
  subtotal          Float    @default(0)
  shippingCost      Float    @default(0)
  tax               Float    @default(0)
  totalAmount       Float    @default(0)
  currency          String   @default("EUR")
  // Pagamento
  paymentRef        String?
  paymentMethod     String?
  atlasPaymentId    String?
  atlasPaymentStatus String?
  paidAt            DateTime?
  // Dados de faturação (JSON)
  billingData       String?
  // Notas e locale
  notes             String?
  locale            String   @default("pt")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile    Profile?    @relation(fields: [profileId], references: [id])
  orderItems OrderItem[]
  invoices   Invoice[]
}

// ─── Itens da Encomenda ─────────────────────────────────────────────────────
model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productId   String
  productName String?
  productSku  String?
  quantity    Int    @default(1)
  unitPrice   Float
  totalPrice  Float?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Faturas ─────────────────────────────────────────────────────────────────
model Invoice {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique
  orderId        String   @unique
  // Emitente
  issuerName     String   @default("Azores Meet, Lda")
  issuerVat      String   @default("513553169")
  issuerAddress  String?
  // Cliente
  customerName   String?
  customerEmail  String?
  customerVat    String?
  customerAddress String?
  // Valores
  subtotal       Float    @default(0)
  tax            Float    @default(0)
  total          Float    @default(0)
  currency       String   @default("EUR")
  // PDF
  pdfUrl         String?
  pdfKey         String?
  // Estado
  status         String   @default("issued") // draft, issued, cancelled
  issuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// ─── Sessões de Chat (Maria da Terra) ───────────────────────────────────────
model ChatSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  userId    String?
  messages  String?  // JSON array: { role, content, timestamp }[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
